---
export const prerender = false;
import Base from '../layouts/Base.astro';
import { sanityClient } from '../lib/sanity';
import HeroSection from '../components/sections/HeroSection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import VenueSection from '../components/sections/VenueSection.astro';

const SECTION_COMPONENTS = {
  heroSection:  HeroSection,
  aboutSection: AboutSection,
  venueSection: VenueSection,
};

// The home page is a regular Sanity page document with slug "home"
const page = await sanityClient.fetch(
  `*[_type == "page" && slug.current == "home"][0]`
);
---

<Base title={page?.title}>
  {page ? (
    (page.sections ?? []).map((section: any) => {
      const Component = SECTION_COMPONENTS[section._type as keyof typeof SECTION_COMPONENTS];
      return Component ? <Component section={section} /> : null;
    })
  ) : (
    <div class="max-w-4xl mx-auto px-4 py-24 text-center text-gray-400">
      <p>Create a page in Sanity with slug <code>home</code> to get started.</p>
    </div>
  )}
</Base>
