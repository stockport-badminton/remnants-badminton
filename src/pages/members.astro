---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import MemberCard from '../components/MemberCard.astro';

const allMembers = await getCollection('members');
const members = allMembers
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Base title="Members">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="mb-10">
      <h1 class="text-3xl font-bold text-primary mb-2">The Rogues Gallery</h1>
      <p class="text-gray-600">Meet the members of Remnants Badminton Club.</p>
    </div>

    {members.length === 0 ? (
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-10 text-center text-gray-500">
        <div class="text-4xl mb-3" aria-hidden="true">🏸</div>
        <p class="font-medium">No members added yet.</p>
        <p class="text-sm mt-1">
          Log in to the <a href="/admin/" class="text-secondary hover:underline">club admin</a> to add members.
        </p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {members.map((member) => (
          <MemberCard
            name={member.data.name}
            role={member.data.role}
            bio={member.data.bio}
            photo={member.data.photo}
          />
        ))}
      </div>
    )}
  </div>
</Base>
