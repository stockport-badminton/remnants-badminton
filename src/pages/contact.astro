---
import Base from '../layouts/Base.astro';
import homeData from '../data/home.json';
---

<Base title="Contact Us">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-2 gap-12">

      <!-- Left: form -->
      <div>
        <h1 class="text-3xl font-bold text-primary mb-2">Contact Us</h1>
        <p class="text-gray-600 mb-8">
          Got a question or interested in joining? Drop us a message and we'll get back to you.
        </p>

        <!-- Success message (shown after redirect) -->
        {Astro.url.searchParams.get('success') === '1' && (
          <div class="bg-green-50 border border-green-300 text-green-800 rounded-xl p-4 mb-6 flex gap-3">
            <svg class="w-5 h-5 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <p class="font-medium">Message sent! We'll be in touch shortly.</p>
          </div>
        )}

        <!--
          Netlify Forms: the data-netlify attribute tells Netlify to handle this form.
          No email addresses are exposed in the source — Netlify emails the submission
          to the address configured in the Netlify dashboard.
        -->
        <form
          name="contact"
          method="POST"
          action="/contact?success=1"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-5"
        >
          <input type="hidden" name="form-name" value="contact" />
          <!-- Honeypot field — hidden from real users, catches bots -->
          <p class="hidden" aria-hidden="true">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Your name *</label>
            <input
              id="name"
              name="name"
              type="text"
              required
              autocomplete="name"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
              placeholder="Jane Smith"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email address *</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors"
              placeholder="jane@example.com"
            />
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">Subject *</label>
            <select
              id="subject"
              name="subject"
              required
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors bg-white"
            >
              <option value="">Please select…</option>
              <option value="joining">Interested in joining</option>
              <option value="general">General enquiry</option>
              <option value="fixtures">Fixtures / results</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-colors resize-y"
              placeholder="Tell us a bit about yourself…"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-primary text-white font-semibold py-3 px-6 rounded-lg hover:opacity-90 transition-opacity focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary"
          >
            Send message
          </button>

          <p class="text-xs text-gray-400 text-center">
            Your details are only used to respond to your enquiry and are never shared.
          </p>
        </form>
      </div>

      <!-- Right: info + map -->
      <div class="space-y-8">
        <div>
          <h2 class="text-lg font-semibold text-primary mb-3">Where we play</h2>
          <p class="text-gray-700 font-medium">{homeData.venueAddress}</p>
          <a
            href={`https://www.google.com/maps/dir/?api=1&destination=${homeData.venueLat},${homeData.venueLng}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-secondary text-sm font-medium mt-2 hover:underline"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Get directions
          </a>
        </div>

        <div class="rounded-xl overflow-hidden border border-gray-200 shadow-sm">
          <iframe
            src={`https://www.google.com/maps?q=${homeData.venueLat},${homeData.venueLng}&z=15&output=embed`}
            width="100%"
            height="300"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Lymm Leisure Centre on Google Maps"
          ></iframe>
        </div>

        <div class="bg-primary/5 border border-primary/20 rounded-xl p-5">
          <h2 class="text-sm font-semibold text-primary mb-2">Interested in joining?</h2>
          <p class="text-sm text-gray-600">
            We welcome players of all abilities. Send us a message using the form and we'll let you know about our next session.
          </p>
        </div>
      </div>
    </div>
  </div>
</Base>
