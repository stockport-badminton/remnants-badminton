---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import theme from '../data/theme.json';
import { sanityClient } from '../lib/sanity';

const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]{ navLinks }`);
const navLinks = settings?.navLinks ?? undefined;

interface Props {
  title?: string;
  description?: string;
}

const {
  title = theme.siteName,
  description = theme.tagline,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === theme.siteName ? title : `${title} | ${theme.siteName}`}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style set:html={`
      :root {
        --color-primary: ${theme.primaryColor};
        --color-secondary: ${theme.secondaryColor};
        --color-accent: ${theme.accentColor};
      }
    `}></style>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900 font-sans">
    <Nav siteName={theme.siteName} links={navLinks} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer siteName={theme.siteName} tagline={theme.tagline} />
  </body>
</html>
