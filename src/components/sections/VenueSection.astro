---
interface Props {
  section: {
    heading?: string;
    address: string;
    lat: number;
    lng: number;
  };
}
const { section } = Astro.props;
---

<section class="max-w-5xl mx-auto px-4 py-16">
  {section.heading && (
    <h2 class="text-2xl font-bold text-primary mb-2">{section.heading}</h2>
  )}
  <p class="text-gray-600 mb-6">{section.address}</p>
  <div class="rounded-xl overflow-hidden border border-gray-200 shadow-sm">
    <iframe
      src={`https://www.google.com/maps?q=${section.lat},${section.lng}&z=15&output=embed`}
      width="100%"
      height="400"
      style="border:0;"
      allowfullscreen
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Venue location on Google Maps"
    ></iframe>
  </div>
  <div class="mt-4">
    <a
      href={`https://www.google.com/maps/dir/?api=1&destination=${section.lat},${section.lng}`}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 text-secondary text-sm font-medium hover:underline"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      Get directions
    </a>
  </div>
</section>
