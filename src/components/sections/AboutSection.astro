---
interface Props {
  section: {
    heading?: string;
    body: string;
  };
}
const { section } = Astro.props;
---

<section class="max-w-4xl mx-auto px-4 py-16">
  {section.heading && (
    <h2 class="text-3xl font-bold text-primary mb-4">{section.heading}</h2>
  )}
  {section.body.split('\n\n').map((para) => (
    <p class="text-gray-600 mb-4 leading-relaxed">{para}</p>
  ))}
</section>
