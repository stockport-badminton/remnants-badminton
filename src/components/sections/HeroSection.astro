---
interface Props {
  section: {
    heading: string;
    subheading?: string;
    ctaText?: string;
    ctaUrl?: string;
  };
}
const { section } = Astro.props;
---

<div class="bg-primary text-white py-20 px-4">
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-12">

    <div class="flex-shrink-0">
      <img src="/logo.jpg" alt={section.heading} class="h-48 w-auto rounded-xl" />
    </div>

    <div class="text-center md:text-left">
      {section.subheading && (
        <p class="text-xl mb-8 opacity-90">{section.subheading}</p>
      )}
      {section.ctaText && section.ctaUrl && (
        <a href={section.ctaUrl}
           class="inline-block bg-white text-primary font-semibold px-8 py-3 rounded-lg hover:opacity-90 transition-opacity">
          {section.ctaText}
        </a>
      )}
    </div>

  </div>
</div>
