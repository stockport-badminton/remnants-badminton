---
interface Props {
  section: {
    heading: string;
    subheading?: string;
    ctaText?: string;
    ctaUrl?: string;
  };
}
const { section } = Astro.props;
---

<div class="bg-primary text-white py-20 px-4 text-center">
  <h1 class="text-4xl font-bold mb-4">{section.heading}</h1>
  {section.subheading && (
    <p class="text-xl mb-8 opacity-90">{section.subheading}</p>
  )}
  {section.ctaText && section.ctaUrl && (
    <a href={section.ctaUrl}
       class="inline-block bg-white text-primary font-semibold px-8 py-3 rounded-lg hover:opacity-90 transition-opacity">
      {section.ctaText}
    </a>
  )}
</div>
