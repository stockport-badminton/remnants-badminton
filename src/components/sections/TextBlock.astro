---
interface Props {
  section: {
    heading?: string;
    body: string;
  };
}
const { section } = Astro.props;
---

<div class="max-w-3xl mx-auto px-4 py-12">
  {section.heading && (
    <h2 class="text-2xl font-bold text-primary mb-4">{section.heading}</h2>
  )}
  <p class="text-gray-700 leading-relaxed whitespace-pre-line">{section.body}</p>
</div>
